   "source": [
    "def run_experiment(experiment_id, hidden_sizes, dropout_p, use_batchnorm, optimizer_name, lr, momentum=0.0, weight_decay=0.0, epochs=5, patience=None):\n",
    "    set_seed(SEED)\n",
    "    model = MLP(hidden_sizes=hidden_sizes, dropout_p=dropout_p, use_batchnorm=use_batchnorm).to(device)\n",
    "    optimizer = make_optimizer(model, optimizer_name, lr=lr, momentum=momentum, weight_decay=weight_decay)\n",
    "    best_state_dict = None\n",
    "    best_val_accuracy = -1.0\n",
    "    history = []\n",
    "    patience_counter = 0\n",
    "    for epoch in range(epochs):\n",
    "        train_loss, train_acc = train_one_epoch(model, train_loader, criterion, optimizer, device)\n",
    "        val_loss, val_acc = evaluate(model, val_loader, criterion, device)\n",
    "        history.append((epoch + 1, train_loss, train_acc, val_loss, val_acc))\n",
    "        if val_acc > best_val_accuracy:\n",
    "            best_val_accuracy = val_acc\n",
    "            best_state_dict = copy.deepcopy(model.state_dict())\n",
    "            patience_counter = 0\n",
    "        else:\n",
    "            patience_counter += 1\n",
    "        if patience is not None and patience_counter >= patience:\n",
    "            break\n",
    "    if best_state_dict is not None:\n",
    "        model.load_state_dict(best_state_dict)\n",
    "    test_loss, test_acc = evaluate(model, test_loader, criterion, device)\n",
    "    return model, history, best_val_accuracy, test_acc\n",
    "\n",
    "experiments = [\n",
    "    {\"experiment_id\": \"E1\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.0, \"use_batchnorm\": False, \"optimizer\": \"Adam\", \"lr\": 1e-3, \"epochs\": 5},\n",
    "    {\"experiment_id\": \"E2\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.3, \"use_batchnorm\": False, \"optimizer\": \"Adam\", \"lr\": 1e-3, \"epochs\": 5},\n",
    "    {\"experiment_id\": \"E3\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.0, \"use_batchnorm\": True,  \"optimizer\": \"Adam\", \"lr\": 1e-3, \"epochs\": 5},\n",
    "    {\"experiment_id\": \"E4\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.0, \"use_batchnorm\": True,  \"optimizer\": \"Adam\", \"lr\": 1e-3, \"epochs\": 8, \"patience\": 3},\n",
    "    {\"experiment_id\": \"O1\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.3, \"use_batchnorm\": False, \"optimizer\": \"Adam\", \"lr\": 1e-1, \"epochs\": 5},\n",
    "    {\"experiment_id\": \"O2\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.3, \"use_batchnorm\": False, \"optimizer\": \"Adam\", \"lr\": 1e-5, \"epochs\": 5},\n",
    "    {\"experiment_id\": \"O3\", \"hidden_sizes\": [256, 128], \"dropout_p\": 0.3, \"use_batchnorm\": False, \"optimizer\": \"SGD\",  \"lr\": 1e-2, \"momentum\": 0.9, \"weight_decay\": 1e-4, \"epochs\": 6},\n",
    "]\n",
    "\n",
    "pd.DataFrame(experiments)"
   ],
